################################################################################
################################################################################
###                                                                          ###
###                            .env.example                                  ###
###                    Environment Variables Template                        ###
###                                                                          ###
###             Copy this file to .env and edit as required.                 ###
###                                                                          ###
################################################################################
################################################################################

# Flask Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-here

# API Keys
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
API_KEY=your-api-key-for-authentication

# Database
DATABASE_PATH=ephemeral.db

# Swiss Ephemeris
SWISS_EPHEMERIS_PATH=./sweph

# Logging
LOG_FILE=google_api_usage.log
LOG_LEVEL=INFO

# API Usage Tracking
USAGE_COUNT_FILE=api_usage_count.json
MAX_MONTHLY_REQUESTS=10000

# CORS Settings
CORS_ORIGINS=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization,X-Requested-With,X-API-Key

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_HOUR=50
RATE_LIMIT_PER_DAY=200

# Cache Settings
CACHE_EXPIRY_DAYS=90